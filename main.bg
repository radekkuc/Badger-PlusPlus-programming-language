let a = 50.0;
let b = 100.0;
let operation = "+";


if(operation == "+") {
    println(a + b);
}

if(operation == "-") {
    println(a - b);
}

if(operation == "*") {
    println(a * b);
}

if(operation == "/") {
    if(b != 0) {
        println(a / b);
    }
    if(b == 0) {
        println("Cannot divide by 0");
    }
}