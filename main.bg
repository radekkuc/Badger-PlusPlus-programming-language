let x = 0;
while(x < 5) {
    println(x);
    x = x + 1;
}

let y = 3;
while(y > 0) {
    println(y);
    y = y - 1;
}

let flag = true;
while(flag) {
    println("flag loop executed once");
    flag = false;
}

let a = 0;
let b = 2;
while((a < 3) && (b < 5)) {
    println(a);
    println(b);
    a = a + 1;
    b = b + 1;
}

let n = 0;
while(!(n == 3)) {
    println(n);
    n = n + 1;
}
